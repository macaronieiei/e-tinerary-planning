{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",       // ← เปลี่ยนจาก nodenext
    "target": "ES2020",         // ← เปลี่ยนจาก esnext
    "types": ["node"],          // ← เพิ่ม node

    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,    // ← เพิ่ม (จำเป็นสำหรับ import * as fs)
    "resolveJsonModule": true,  // ← เพิ่ม
    "skipLibCheck": true,

    // ลบออก (ไม่ต้องการ)
    // "jsx": "react-jsx",
    // "verbatimModuleSyntax": true,
    // "isolatedModules": true,
    // "noUncheckedSideEffectImports": true,
    // "moduleDetection": "force",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}